<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Background Image -->

        <ImageView
            android:id="@+id/backgroundImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/background"/>

        <!-- Main Layout -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- App Name -->

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kavya-Kanaja"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#000000"
                android:padding="8dp"/>

            <!-- Subtitle -->

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kannada Poetry Learning App"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#673AB7"
                android:background="#DDFFFFFF"
                android:padding="5dp"
                android:layout_marginTop="8dp"/>

            <!-- Poem Section -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Poem of the Day"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="#FFFFFF"
                android:padding="4dp"
                android:layout_marginTop="10dp"/>

            <!-- Poem -->

            <TextView
                android:id="@+id/poemTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ನಿಸರ್ಗವೇ ನಮ್ಮ ಜೀವ"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#008000"
                android:background="#FFFFFF"
                android:padding="6dp"
                android:layout_marginTop="8dp"/>

            <!-- Meaning Section -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bhavartha"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="12dp"/>

            <!-- Read Meaning Button -->

            <Button
                android:id="@+id/btnMeaning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Read Meaning"
                android:textSize="22sp"
                android:background="#666666"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"/>

            <!-- Meaning Text -->

            <TextView
                android:id="@+id/meaningText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nature is the source of life and peace."
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#008000"
                android:background="#DDFFFFFF"
                android:padding="6dp"
                android:layout_marginTop="8dp"/>

            <!-- Listen Poem Button -->

            <Button
                android:id="@+id/btnListen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔊 Listen Poem"
                android:textSize="22sp"
                android:background="#666666"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"/>

            <!-- Ask AI Button -->

            <Button
                android:id="@+id/btnAskAI"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✨ Ask AI"
                android:textSize="22sp"
                android:background="#666666"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"/>

            <!-- Poet Information -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Poet Information"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="#FFFFFF"
                android:padding="4dp"
                android:layout_marginTop="15dp"/>

            <!-- Poet Image -->

            <ImageView
                android:id="@+id/poetImage"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:src="@drawable/kuvempu"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"/>

            <!-- Poet Name -->

            <TextView
                android:id="@+id/poetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kuvempu"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#00FF00"
                android:layout_marginTop="10dp"/>

            <!-- Poet Description -->

            <TextView
                android:id="@+id/poetDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Famous Kannada poet and Jnanpith award winner."
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#8B2500"
                android:background="#CCCCCC"
                android:gravity="center"
                android:padding="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>

    </RelativeLayout>

</ScrollView>